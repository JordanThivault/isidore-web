# Resend — clé API pour l'envoi des emails du formulaire de contact
# https://resend.com/api-keys
RESEND_API_KEY=

# Adresse qui reçoit les demandes de contact
CONTACT_TO_EMAIL=jordan@isidoreweb.fr

# Expéditeur vérifié dans Resend (domaine à valider dans Resend > Domains)
CONTACT_FROM_EMAIL=contact@isidoreweb.fr
